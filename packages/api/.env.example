NODE_ENV=development
PORT=4000
ALLOWED_ORIGIN=http://localhost:3000
OPENAI_API_KEY=
OPENAI_ADMIN_KEY=

# Database backups to Cloudflare R2 (see README "Database Backups").
# Leave ENABLE_BACKUP=false to keep backups off. When true, all R2_* vars below
# are required, otherwise the scheduler logs a warning and stays idle.
ENABLE_BACKUP=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
