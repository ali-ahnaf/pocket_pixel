NODE_ENV=development
PORT=4000
ALLOWED_ORIGIN=http://localhost:3000
OPENAI_API_KEY=
OPENAI_ADMIN_KEY=

# Public origin of the API. The fixed Google OAuth redirect URI is derived from
# this as ${APP_BASE_URL}/api/oauth/google/callback and every user must register
# that exact URI in their own Google OAuth client. In production the API also
# serves the UI, so this is the app's public origin.
APP_BASE_URL=http://localhost:4000
# Where the browser is sent after the OAuth callback. Defaults to APP_BASE_URL;
# in dev set it to the Next dev server so the redirect lands on the UI.
WEB_BASE_URL=http://localhost:3000

# 32-byte key (base64-encoded) used to AES-256-GCM encrypt per-user Google OAuth
# credentials at rest (see utils/oauth-credentials-encryption.util.ts). Required —
# there is no default; generate with: openssl rand -base64 32
OAUTH_CREDENTIALS_ENCRYPTION_KEY=

# Database backups to Cloudflare R2 (see README "Database Backups").
# Leave ENABLE_BACKUP=false to keep backups off. When true, all R2_* vars below
# are required, otherwise the scheduler logs a warning and stays idle.
ENABLE_BACKUP=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
